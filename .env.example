# Режим отладки: при true сохраняются html/json/png и доступны /files
DEBUG=true
LOG_LEVEL=DEBUG
DEBUG_DIR=app/debug
API_PREFIX=/api/v1

# Ключ межсервисной авторизации (сейчас не проверяется — заглушка)
SERVICE_API_KEY=

# Kafka (журнал событий). Если выключено — сервис работает без журнала.
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=parsing-events

# --- Политика Ozon (таймауты/паузы/ретраи именно для Ozon) ---
OZON_HEADLESS=true
OZON_PAGE_LOAD_TIMEOUT=30
OZON_WAIT_TIMEOUT=15
OZON_PAUSE_MIN=2.0
OZON_PAUSE_MAX=4.0
OZON_RETRIES=3
OZON_RETRY_PAUSE_MIN=20.0
OZON_RETRY_PAUSE_MAX=40.0
