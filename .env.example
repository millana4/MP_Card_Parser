# Режим
DEBUG=false
LOG_LEVEL=INFO
DEBUG_DIR=app/debug
API_PREFIX=/api/v1

# Ключ межсервисной авторизации
SERVICE_API_KEY=string

# Kafka
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:port
KAFKA_TOPIC=parsing-events
OZON_GEO_CODE=spb
OZON_GEO_NAME=Санкт-Петербург
KAFKA_GROUP_ID=ozon-parser-spb
KAFKA_POLL_TIMEOUT_MS=1000
KAFKA_RECONNECT_DELAY_S=5

# --- Политика Ozon
OZON_HEADLESS=true
OZON_PAGE_LOAD_TIMEOUT=30
OZON_WAIT_TIMEOUT=15
OZON_PAUSE_MIN=2.0
OZON_PAUSE_MAX=4.0
OZON_RETRIES=3
OZON_MAX_PAGES=10
OZON_MIN_RATING=4.8
OZON_MIN_REVIEWS=100
OZON_RETRY_PAUSE_MIN=20.0
OZON_RETRY_PAUSE_MAX=40.0
